# ═══════════════════════════════════════════════════════════
# CRUNCHTIME BULLIES — Environment Variables
# ═══════════════════════════════════════════════════════════

# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=ic4pnlo7
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=                          # write token for seed scripts

# Medusa Commerce Backend
NEXT_PUBLIC_MEDUSA_BACKEND_URL=            # e.g. https://crunchtyme-medusa.fly.dev
MEDUSA_API_KEY=                            # publishable API key from Medusa admin

# Stripe Payments (processed through Medusa)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=        # pk_live_... or pk_test_...

# Site
NEXT_PUBLIC_SITE_URL=https://crunchtymebullies.com

# Revalidation
SANITY_REVALIDATE_SECRET=                  # webhook secret for on-demand ISR
